{
  "name": "project-seal",
  "version": "0.1.0",
  "private": true,
  "description": "Project Seal: a bilingual white baby seal desktop pet MVP.",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build && node scripts/copy-mediapipe-assets.js",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "package:win": "electron-builder --win",
    "dashboard": "node scripts/generate-project-dashboard.cjs"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@mediapipe/selfie_segmentation": "^0.1.1675465747",
    "pixi.js": "^8.6.6",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "vitest": "^4.1.9"
  },
  "build": {
    "appId": "com.projectseal.desktop",
    "productName": "Project Seal",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "assets/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    }
  }
}
